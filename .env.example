# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in your real values.
# The .env file is git-ignored and must NEVER be committed.
#
# .env.exemple — Copiez ce fichier vers .env et remplissez vos vraies valeurs.
# Le fichier .env est ignoré par git et ne doit JAMAIS être commité.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL / Neon DB ──────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>/<dbname>?sslmode=require&channel_binding=require
SPRING_DATASOURCE_USERNAME=<your_db_username>
SPRING_DATASOURCE_PASSWORD=<your_db_password>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string (min 32 chars) / Utilisez une longue chaîne aléatoire (min 32 chars)
APP_JWT_SECRET=<your_very_long_random_jwt_secret_key_here>
APP_JWT_EXPIRATION=86400000

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── JPA ───────────────────────────────────────────────────────────────────────
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_LEVEL_SQL=WARN
